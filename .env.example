# ============================================
# NexAd Frontend — Environment Variables
# ============================================
# Copy to .env.local and customize.
# NEVER commit .env.local to version control!

# ── Backend API (RunPod) ──────────────────────
# Required: URL to the NexAd backend API on RunPod
BACKEND_API_URL=https://your-runpod-id.proxy.runpod.net/api/v1
BACKEND_API_KEY=__GENERATE_WITH_OPENSSL_RAND_HEX_32__

# Legacy env vars (for compatibility)
NEXT_PUBLIC_API_URL=https://your-runpod-id.proxy.runpod.net/api/v1

# ── Security ──────────────────────────────────
# Required: HMAC secret for CSRF protection (generate with: openssl rand -hex 32)
CSRF_HMAC_SECRET=__GENERATE_WITH_OPENSSL_RAND_HEX_32__

# ── Service URLs (for Next.js rewrites) ───────
# These are used by next.config.ts for API proxying
NEXUS_AUTH_URL=http://localhost:5000
NEXUS_CORE_URL=http://localhost:5001
NEXUS_BRAIN_URL=http://localhost:5005
NEXUS_RULES_URL=http://localhost:5003
NEXUS_IOT_URL=http://localhost:5002
NEXUS_API_GATEWAY=http://localhost:8080
